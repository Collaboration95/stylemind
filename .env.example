# StyleMind Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Chat LLM (default: Groq + Llama 3.3 70B) ───────────────────────────────────
# Swap provider by changing CHAT_BASE_URL + CHAT_MODEL — zero code changes
# Compatible with any OpenAI-compatible API endpoint.
CHAT_BASE_URL=https://api.groq.com/openai/v1
CHAT_API_KEY=gsk_your_groq_api_key_here
CHAT_MODEL=llama-3.3-70b-versatile
CHAT_TEMPERATURE=0.7

# ── Extraction LLM (default: OpenAI gpt-4.1-nano) ───────────────────────────────
# Used for silent structured persona signal extraction after each turn.
# Requires reliable structured/JSON output support.
# Swap EXTRACTION_BASE_URL + EXTRACTION_MODEL to use another provider.
EXTRACTION_BASE_URL=https://api.openai.com/v1
EXTRACTION_API_KEY=sk-proj-your_openai_api_key_here
EXTRACTION_MODEL=gpt-4.1-nano

# ── Neo4j Graph Database ────────────────────────────────────────────────────────
# Local default: bolt://localhost:7687 (matches docker-compose service)
# Change NEO4J_URI to bolt://<host>:7687 for remote/cloud instances.
# Both the graph store and vector index live in the same Neo4j database.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=stylemind_secret

# ── Embeddings ──────────────────────────────────────────────────────────────────
# local: sentence-transformers/all-MiniLM-L6-v2 (no API key needed, 384 dims)
# openai: text-embedding-3-small (requires EXTRACTION_API_KEY, 1536 dims)
# EMBEDDING_PROVIDER=openai to switch — also update EMBEDDING_MODEL + EMBEDDING_DIMENSIONS.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# ── Langfuse Observability (optional — graceful degradation if not set) ──────────
# Self-hosted: set LANGFUSE_HOST=http://localhost:3000 (matches docker-compose)
# Cloud:       https://us.cloud.langfuse.com  or  https://cloud.langfuse.com
# Leave LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY empty to disable tracing.
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=http://localhost:3000

# ── Langfuse Infrastructure (docker-compose) ────────────────────────────────────
# These are used by docker-compose.yml to configure the self-hosted Langfuse server.
LANGFUSE_DB_PASSWORD=changeme_langfuse_db
LANGFUSE_NEXTAUTH_SECRET=changeme_langfuse_nextauth
LANGFUSE_SALT=changeme_langfuse_salt

# ── API Security ────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Use "*" for local dev only. Always restrict in production.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ── App Settings ────────────────────────────────────────────────────────────────
# LOG_LEVEL: Python logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# VECTOR_TOP_K: number of candidates retrieved from vector index per query
VECTOR_TOP_K=10
# PERSONA_DECAY_RATE: exponential decay rate applied to persona signal weights per turn
PERSONA_DECAY_RATE=0.15
# EXPECTED_SIGNALS_PER_TURN: used to compute persona confidence score
EXPECTED_SIGNALS_PER_TURN=3.0
# MIN_SIMILARITY_THRESHOLD: minimum cosine similarity for a retrieved product to qualify
MIN_SIMILARITY_THRESHOLD=0.3
