# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=stylemind_secret

# ── Chat LLM (default: Groq + Llama 3.3 70B) ───────────────────────────────────
# Swap provider by changing CHAT_BASE_URL + CHAT_MODEL — zero code changes
CHAT_BASE_URL=https://api.groq.com/openai/v1
CHAT_API_KEY=your-groq-api-key-here
CHAT_MODEL=llama-3.3-70b-versatile
CHAT_TEMPERATURE=0.7

# ── Extraction LLM (default: OpenAI gpt-4.1-nano) ───────────────────────────────
# Used for structured persona signal extraction (constrained JSON output)
EXTRACTION_BASE_URL=https://api.openai.com/v1
EXTRACTION_API_KEY=your-openai-api-key-here
EXTRACTION_MODEL=gpt-4.1-nano

# ── Embeddings ──────────────────────────────────────────────────────────────────
# local: sentence-transformers/all-MiniLM-L6-v2 (no API key, 384 dims)
# openai: text-embedding-3-small (requires OPENAI_API_KEY, 1536 dims)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# ── Langfuse (self-hosted observability) ─────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=http://localhost:3000

# ── App Settings ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
VECTOR_TOP_K=10
PERSONA_DECAY_RATE=0.15
EXPECTED_SIGNALS_PER_TURN=3.0
MIN_SIMILARITY_THRESHOLD=0.3
